<section class="verify-otp-page">
  <div class="verify-otp-container">
    <h1 class="verify-otp-title"><%= titulo %></h1>
    <p class="verify-otp-message"><%= message %></p>

    <form id="verifyOtpForm" class="verify-otp-form">
      <div class="form-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" value="jeanwagner646@gmail.com" readonly required>
      </div>
      <div class="form-group">
        <label for="otp">Código de Verificação</label>
        <input type="text" id="otp" name="otp" placeholder="Insira seu código OTP" required maxlength="6">
      </div>
      <button type="submit" class="btn-primary">Verificar</button>
    </form>

    <script>
      document.getElementById('verifyOtpForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const form = e.target;
        const formData = new URLSearchParams(new FormData(form));
        
        try {
          const response = await fetch('/verify-otp', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: formData.toString()
          });
          
          const contentType = response.headers.get("content-type");
          let result;
          if (contentType && contentType.includes("application/json")) {
            result = await response.json();
          } else {
            result = await response.text();
          }
          
          if (response.ok) {
            console.log('Verificação OTP com sucesso:', result);
            if (typeof showNotification === 'function') {
                showNotification(result.message || 'Email verificado com sucesso!', 'success');
            } else {
                alert(result.message || 'Email verificado com sucesso!');
            }
            setTimeout(() => {
                if (result.redirect) {
                    window.location.href = result.redirect;
                } else {
                    window.location.href = '/login'; // Padrão para login após verificação
                }
            }, 1000);
          } else {
            console.error('Erro na verificação OTP:', result);
            if (typeof showNotification === 'function') {
                showNotification(result.message || 'Erro ao verificar código OTP', 'error');
            } else {
                alert(result.message || 'Erro ao verificar código OTP');
            }
          }
        } catch (error) {
          console.error('Erro de rede:', error);
          if (typeof showNotification === 'function') {
              showNotification('Erro de conexão ao tentar verificar OTP.', 'error');
          } else {
              alert('Erro de conexão ao tentar verificar OTP.');
          }
        }
      });
    </script>

    <p class="resend-otp-prompt">Não recebeu o código? <a href="/send-otp?email=Jeanwagner646@gmail.com" class="resend-otp-link">Reenviar código</a></p>
  </div>
</section>

<style>
  .verify-otp-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 70vh;
    background-color: var(--cor-fundo-claro);
    padding: var(--espacamento-grande);
  }

  .verify-otp-container {
    background-color: #fff;
    padding: var(--espacamento-grande);
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 450px;
    text-align: center;
  }

  .verify-otp-title {
    color: var(--cor-primaria);
    margin-bottom: var(--espacamento-medio);
    font-family: var(--fonte-titulo);
  }

  .verify-otp-message {
    color: var(--cor-texto-escuro);
    margin-bottom: var(--espacamento-grande);
  }

  .verify-otp-form .form-group {
    margin-bottom: var(--espacamento-medio);
    text-align: left;
  }

  .verify-otp-form label {
    display: block;
    margin-bottom: var(--espacamento-pequeno);
    color: var(--cor-texto-escuro);
    font-weight: bold;
  }

  .verify-otp-form input[type="email"],
  .verify-otp-form input[type="text"] {
    width: 100%;
    padding: var(--espacamento-medio);
    border: 1px solid var(--cor-borda);
    border-radius: 4px;
    box-sizing: border-box;
    font-size: 1rem;
  }

  .verify-otp-form input[type="email"]:focus,
  .verify-otp-form input[type="text"]:focus {
    border-color: var(--cor-secundaria);
    outline: none;
    box-shadow: 0 0 0 2px rgba(var(--cor-secundaria-rgb), 0.2);
  }

  .btn-primary {
    background-color: var(--cor-secundaria);
    color: var(--cor-texto-claro);
    padding: var(--espacamento-medio) var(--espacamento-grande);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    transition: background-color 0.3s ease;
    width: 100%;
    margin-top: var(--espacamento-medio);
  }

  .btn-primary:hover {
    filter: brightness(90%);
  }

  .resend-otp-prompt {
    margin-top: var(--espacamento-grande);
    color: var(--cor-texto-escuro);
  }

  .resend-otp-link {
    color: var(--cor-primaria);
    text-decoration: none;
  }

  .resend-otp-link:hover {
    text-decoration: underline;
  }
</style>