<section class="login-page">
  <div class="login-container">
    <h1 class="login-title"><%= titulo %></h1>
    <p class="login-message"><%= message %></p>

    <form id="loginForm" class="login-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="email">E-mail ou Usuário</label>
        <input type="text" id="email" name="email" placeholder="Seu e-mail ou nome de usuário" required>
      </div>
      <div class="form-group">
        <label for="password">Senha</label>
        <input type="password" id="password" name="password" placeholder="Sua senha" required>
      </div>
      <div class="form-options">
        <div class="remember-me">
          <input type="checkbox" id="rememberMe" name="rememberMe">
          <label for="rememberMe">Lembrar-me</label> 
        </div>
        <a href="/forgot-password" class="forgot-password-link" hx-get="/forgot-password" hx-target="#main-content" hx-swap="innerHTML" hx-push-url="true">Esqueceu a senha?</a>
      </div>
      <button type="submit" class="btn-primary">Entrar</button>
    </form>

    <script>
      document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const form = e.target;
        const formData = new URLSearchParams(new FormData(form));
        
        try {
          const response = await fetch('/login', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: formData.toString()
          });
          
          const contentType = response.headers.get("content-type");
          let result;
          if (contentType && contentType.includes("application/json")) {
            result = await response.json();
          } else {
            result = await response.text();
          }
          
          if (response.ok) {
            console.log('Login com sucesso:', result);
            if (typeof showNotification === 'function') {
                showNotification('Login realizado com sucesso!', 'success');
            } else {
                alert('Login realizado com sucesso!');
            }
            setTimeout(() => {

              if (result.user.role === 'admin') {
                window.location.href = '/admin/dashboard';
              } else if (result.user.role === 'user') {
                window.location.href = '/profile'; 
                
              }
            }, 1000);
          } else {
            console.error('Erro no login:', result);
            if (typeof showNotification === 'function') {
                showNotification(result.message || 'Erro ao realizar login', 'error');
            } else {
                alert(result.message || 'Erro ao realizar login');
            }
          }
        } catch (error) {
          console.error('Erro de rede:', error);
          if (typeof showNotification === 'function') {
              showNotification('Erro de conexão ao tentar fazer login.', 'error');
          } else {
              alert('Erro de conexão ao tentar fazer login.');
          }
        }
      });
    </script>

    <p class="register-prompt">Não tem uma conta? <a href="/register" class="register-link" hx-get="/register" hx-target="#main-content" hx-swap="innerHTML" hx-push-url="true">Crie uma agora!</a></p>
  </div>
</section>

<style>
  .login-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 78vh; /* Ajuste conforme a altura do seu header */
    background-color: var(--cor-fundo-claro);
    padding: var(--espacamento-grande);
  }

  .login-container {
    background-color: #fff;
    padding: var(--espacamento-grande);
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .login-title {
    color: var(--cor-primaria);
    margin-bottom: var(--espacamento-medio);
    font-family: var(--fonte-titulo);
  }

  .login-message {
    color: var(--cor-texto-escuro);
    margin-bottom: var(--espacamento-grande);
  }

  .login-form .form-group {
    margin-bottom: var(--espacamento-medio);
    text-align: left;
  }

  .login-form label {
    display: block;
    margin-bottom: var(--espacamento-pequeno);
    color: var(--cor-texto-escuro);
    font-weight: bold;
  }

  .login-form input[type="text"],
  .login-form input[type="password"] {
    width: 100%;
    padding: var(--espacamento-medio);
    border: 1px solid var(--cor-borda);
    border-radius: 4px;
    box-sizing: border-box; /* Garante que padding não aumente a largura total */
    font-size: 1rem;
  }

  .login-form input[type="text"]:focus,
  .login-form input[type="password"]:focus {
    border-color: var(--cor-secundaria);
    outline: none;
    box-shadow: 0 0 0 2px rgba(var(--cor-secundaria-rgb), 0.2); /* Exemplo de como usar RGB se definido */
  }

  .login-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--espacamento-grande);
    font-size: 0.9rem;
  }

  .remember-me {
    display: flex;
    align-items: center;
  }

  .remember-me input {
    margin-right: var(--espacamento-pequeno);
  }

  .forgot-password-link,
  .register-link {
    color: var(--cor-primaria);
    text-decoration: none;
  }

  .forgot-password-link:hover,
  .register-link:hover {
    text-decoration: underline;
  }

  .btn-primary {
    background-color: var(--cor-secundaria);
    color: var(--cor-texto-claro);
    padding: var(--espacamento-medio) var(--espacamento-grande);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    transition: background-color 0.3s ease;
    width: 100%;
    margin-top: var(--espacamento-medio);
  }

  .btn-primary:hover {
    background-color: darken(var(--cor-secundaria), 10%); /* Isso exigiria um pré-processador CSS */
    /* Alternativa simples: */
    filter: brightness(90%);
  }

  .register-prompt {
    margin-top: var(--espacamento-grande);
    color: var(--cor-texto-escuro);
  }
</style>
