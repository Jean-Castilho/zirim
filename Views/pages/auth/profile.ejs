<section class="profile-page">
  <div class="profile-container">
    <h1 class="profile-title"><%= titulo %></h1>
    <p class="profile-message"><%= message %></p>

    <div class="profile-content">
      <div class="user-info-card">
        <h2>Informações do Usuário</h2>
        <div class="info-group">
          <label>Nome:</label>
          <p><%= user?.name || 'Não informado' %></p>
        </div>
        <div class="info-group">
          <label>Email:</label>
          <p>
            <%= user?.email?.endereco || 'Não informado' %> 
            <% if (user?.email?.endereco) { %>
              <span class="badge <%= user?.email?.verified ? 'verified' : 'unverified' %>">
                <%= user?.email?.verified ? 'Verificado' : 'Não verificado' %>
              </span>
            <% } %>
          </p>
        </div>
        <div class="info-group">
          <label>Telefone:</label>
          <p>
            <%= user?.phone?.number || 'Não informado' %> 
            <% if (user?.phone?.number) { %>
              <span class="badge <%= user?.phone?.verified ? 'verified' : 'unverified' %>">
                <%= user?.phone?.verified ? 'Verificado' : 'Não verificado' %>
              </span>
            <% } %>
          </p>
        </div>
        <div class="info-group">
          <label>Cargo:</label>
          <p><%= user?.role === 'admin' ? 'Administrador' : 'Usuário' %></p>
        </div>
        <div class="profile-actions" style="margin-top: 1rem;">
          <a href="/logout" class="btn-logout">Sair da Conta</a>
        </div>
      </div>

      <div class="user-orders-card">
        <h2>Meus Pedidos</h2>
        <% if (user?.orderns && user.orderns.length > 0) { %>
          <ul class="orders-list">
            <% user.orderns.forEach(order => { %>
              <li class="order-item">
                <div class="order-header">
                  <strong>Pedido #<%= order._id || order.id || 'N/A' %></strong>
                  <span class="order-date"><%= new Date(order.createdAt || order.date || Date.now()).toLocaleDateString('pt-BR') %></span>
                </div>
                <div class="order-details">
                  <div class="order-status">Status: <%= order.status || 'Processando' %></div>
                  <div class="order-total">Total: R$ <%= (order.total || 0).toFixed(2) %></div>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="no-orders">Você ainda não realizou nenhum pedido.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>

