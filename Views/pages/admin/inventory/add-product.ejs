
<link rel="stylesheet" href="/css/pages/add-product.css">

<div class="admin-container">
  
  <header class="admin-header">
    <h1><%= titulo %></h1>
    <p><%= message %></p>
  </header>

  <div class="admin-form-wrapper">
    <form action="/products/" method="POST" enctype="multipart/form-data">
      
      <!-- Informações Básicas -->
      <h3 class="form-section-title">Informações Básicas</h3>
      
      <div class="form-grid">
        <div class="form-group grid-group">
          <label for="name" class="form-label">Nome do Produto *</label>
          <input type="text" id="name" name="name" required class="form-control">
        </div>
        
        <div class="form-group grid-group">
          <label for="category" class="form-label">Categoria *</label>
          <select id="category" name="categoria" required class="form-control">
            <option value="">Selecione uma categoria</option>
            <option value="feminino">Moda Feminina</option>
            <option value="masculino">Moda Masculina</option>
            <option value="calcados">Calçados</option>
            <option value="acessorios">Acessórios</option>
            <option value="unissex">Unissex</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="description" class="form-label">Descrição do Produto</label>
        <textarea id="description" name="descricao" rows="4" class="form-control"></textarea>
      </div>

      <!-- Variações -->
      <h3 class="form-section-title">Variações</h3>

      <div class="form-grid">
        <div class="form-group grid-group">
          <label for="colors" class="form-label">Cores Disponíveis</label>
          <input type="text" id="colors" name="cores" class="form-control" placeholder="Ex: Preto, Branco, Vermelho">
          <small class="form-text-muted">Separe as cores por vírgula.</small>
        </div>
        
        <div class="form-group grid-group">
          <label for="sizes" class="form-label">Tamanhos Disponíveis</label>
          <input type="text" id="sizes" name="tamanhos" class="form-control" placeholder="Ex: P, M, G, GG ou 38, 40, 42">
          <small class="form-text-muted">Separe os tamanhos por vírgula.</small>
        </div>
      </div>

      <!-- Preço e Estoque -->
      <h3 class="form-section-title">Preço e Estoque</h3>

      <div class="form-grid" style="margin-bottom: 30px;">
        <div class="form-group grid-group">
          <label for="price" class="form-label">Preço (R$) *</label>
          <input type="number" id="price" name="preco" step="0.01" min="0" required class="form-control" placeholder="0.00">
        </div>
        
        <div class="form-group grid-group">
          <label for="stock" class="form-label">Estoque Inicial *</label>
          <input type="number" id="stock" name="estoque" min="0" required class="form-control" placeholder="0">
        </div>

        

      </div>

      <!-- Imagem -->
      <h3 class="form-section-title">Imagens</h3>

      <div class="form-group">
        <label class="form-label">Imagens do Produto</label>
        
        <input type="text" id="imageUrl" name="imageUrl" class="form-control" style="margin-bottom: 15px;" placeholder="URL da imagem (ex: https://...)">
        
        <div style="text-align: center; color: #888; margin-bottom: 15px;">OU ENVIE ARQUIVOS</div>
        
        <div class="image-upload-zone" onclick="document.getElementById('imageFile').click()">
          <div class="image-upload-icon">📸</div>
          <p class="image-upload-title">Clique aqui para selecionar as imagens</p>
          <p class="image-upload-subtitle">Você pode selecionar várias imagens (JPG, PNG, WEBP)</p>
          <input type="file" id="imageFile" name="imagens" accept="image/*" multiple style="display: none;" onchange="previewImages()">
        </div>
        
        <div id="image-preview" class="image-preview-container"></div>
      </div>



      <script>
        function previewImages() {
          const preview = document.getElementById('image-preview');
          const fileInput = document.getElementById('imageFile');
          preview.innerHTML = ''; // Clear previous previews
          
          if (fileInput.files) {
            Array.from(fileInput.files).forEach((file) => {
              const reader = new FileReader();
              reader.onload = function(e) {
                const imgContainer = document.createElement('div');
                imgContainer.className = 'preview-image-wrapper';
                
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'preview-image';
                
                imgContainer.appendChild(img);
                preview.appendChild(imgContainer);
              }
              reader.readAsDataURL(file);
            });
          }
        }
      </script>

      <!-- Ações -->
      <div class="form-actions">
        <a href="/admin/inventory" class="btn btn-cancel">Cancelar</a>
        <button type="submit" class="btn btn-save">Salvar Produto</button>
      </div>

    </form>
  </div>
</div>